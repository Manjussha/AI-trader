# ─────────────────────────────────────────────────────────────
# TRADING BOT — Environment Configuration
# Copy this file to .env and fill in your broker's credentials
# ─────────────────────────────────────────────────────────────

# ── BROKER SELECTION ──────────────────────────────────────────
# Choose one: groww | angelone | zerodha | upstox
BROKER=groww

# ── ANTHROPIC (AI Advisor) ────────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=

# ─────────────────────────────────────────────────────────────
# GROWW
# Docs: https://developer.groww.in
# ─────────────────────────────────────────────────────────────
GROWW_API_KEY=
GROWW_API_SECRET=
TOTP_SECRET=

# ─────────────────────────────────────────────────────────────
# ANGELONE (Smart API)
# Docs: https://smartapi.angelbroking.com/docs
# Get API key from: https://smartapi.angelbroking.com
# ─────────────────────────────────────────────────────────────
ANGELONE_API_KEY=
ANGELONE_CLIENT_ID=
ANGELONE_PASSWORD=
ANGELONE_TOTP_SECRET=

# ─────────────────────────────────────────────────────────────
# ZERODHA (Kite Connect)
# Docs: https://kite.trade/docs/connect/v3
# Get API key from: https://kite.trade/app
# NOTE: Zerodha charges ₹2000/month for API access
#
# Auth flow:
#   1. Open: https://kite.trade/connect/login?api_key=YOUR_KEY&v=3
#   2. Login → get request_token from redirect URL
#   3. Set ZERODHA_REQUEST_TOKEN below — bot exchanges it on first run
# ─────────────────────────────────────────────────────────────
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_REQUEST_TOKEN=
ZERODHA_ACCESS_TOKEN=

# ─────────────────────────────────────────────────────────────
# UPSTOX
# Docs: https://upstox.com/developer/api-documentation
# Get API key from: https://developer.upstox.com
#
# Auth flow:
#   1. Open: https://api.upstox.com/v2/login/authorization/dialog
#            ?response_type=code&client_id=YOUR_KEY&redirect_uri=YOUR_URI
#   2. Login → get code from redirect URL
#   3. Set UPSTOX_CODE below — bot exchanges it for access_token on first run
# ─────────────────────────────────────────────────────────────
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_CODE=
UPSTOX_REDIRECT_URI=http://localhost:3000/callback
UPSTOX_ACCESS_TOKEN=
