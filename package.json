{
  "name": "groww-mcp-trading",
  "version": "1.0.0",
  "description": "Groww Trading MCP Server with AI Analytics",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "bot": "node trading-bot.mjs",
    "bot:paper": "node trading-bot.mjs --mode paper",
    "bot:watch": "node trading-bot.mjs --mode watch --interval 5",
    "cli": "node cli.mjs",
    "advisor": "node tools/advisor-run.mjs",
    "cache": "node tools/cache-refresh.mjs",
    "q": "node tools/quick.mjs",
    "preset": "node tools/presets.mjs",
    "launch": "node tools/launch.mjs",
    "monitor": "node dashboards/monitor.mjs",
    "portfolio": "node dashboards/portfolio-view.mjs",
    "stock": "node dashboards/stock-view.mjs",
    "dashboard": "node dashboards/server-dashboard.mjs",
    "bridge": "node node-bridge.mjs",
    "agent-ui": "node node-bridge.mjs & python dashboard/run.py"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@mathieuc/tradingview": "^3.5.2",
    "@modelcontextprotocol/sdk": "^1.5.0",
    "dotenv": "^16.4.7",
    "node-fetch": "^3.3.2",
    "puppeteer": "^24.38.0",
    "zod": "^3.23.8"
  }
}
